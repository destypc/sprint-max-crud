# Diz ao Git o que NÃO deve ser enviado para o repositório (GitHub). No seu caso:
# Dependências do Composer (rode "composer install" para recriar)
/vendor/

# Credenciais de e-mail (SMTP) — nunca versionar
/app/config/email.php

# Uploads em runtime — versiona apenas o index.php de proteção
/uploads/*
!/uploads/index.php
